{
  "name": "agent-comms",
  "version": "1.4.2",
  "description": "Cross-harness communication bus for LLM agents — TCP peer mesh with rooms, DMs, presence, and real-time push delivery",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ExaDev/agent-comms.git"
  },
  "homepage": "https://github.com/ExaDev/agent-comms#readme",
  "bugs": "https://github.com/ExaDev/agent-comms/issues",
  "license": "MIT",
  "keywords": [
    "agent",
    "llm",
    "communication",
    "bus",
    "mcp",
    "rooms",
    "dm",
    "presence",
    "cross-harness",
    "pi-package"
  ],
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    ".claude-plugin/"
  ],
  "bin": {
    "agent-comms": "dist/cli.js"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc && printf '#!/usr/bin/env node\n' | cat - dist/cli.js > dist/cli.tmp && mv dist/cli.tmp dist/cli.js",
    "lint": "eslint .",
    "test": "node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "8.0.1",
    "@mariozechner/pi-ai": "0.70.2",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/bun": "1.3.12",
    "@types/node": "^25.6.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.58.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "typebox": "1.1.28",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./dist/bridges/pi"
    ]
  }
}
